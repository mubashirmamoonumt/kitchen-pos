{
  "expo": {
    "name": "MUFAZ Kitchen",
    "slug": "mufaz-kitchen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mufaz-kitchen",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf9f7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mufaz.kitchen"
    },
    "android": {
      "package": "com.mufaz.kitchen"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://mufazpos.m3toolskit.shop/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
